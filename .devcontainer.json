{
  "name": "kinflasy-api",
  "dockerComposeFile": [
    "docker-compose.yml"
  ],
  "service": "api",
  "workspaceFolder": "/home/dev/api",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.java",
        "vmware.vscode-boot-dev-pack",
        "redhat.vscode-xml",
        "redhat.vscode-yaml",
        "cweijan.vscode-database-client2"
      ],
      "settings": {
        "java.jdt.ls.home": "/usr/lib/jvm/java-17-openjdk-amd64",
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-17",
            "path": "/usr/lib/jvm/java-17-openjdk-amd64",
            "default": true
          }
        ],
        "java.compile.nullAnalysis.mode": "automatic",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "git config --global --add safe.directory /home/dev/api && git checkout develop"
}